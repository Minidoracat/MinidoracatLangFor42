    {
      "category": "里→裡",
      "description": "「裡面」的「裡」被保留為「里」",
      "rules": [
        {"pattern": "里面", "replacement": "裡面"},
        {"pattern": "這里", "replacement": "這裡"},
        {"pattern": "那里", "replacement": "那裡"},
        {"pattern": "哪里", "replacement": "哪裡"},
        {"pattern": "心里", "replacement": "心裡"},
        {"pattern": "家里", "replacement": "家裡"},
