        {"pattern": "屋里", "replacement": "屋裡"},
        {"pattern": "東西里", "replacement": "東西裡"},
        {"pattern": "劇本里", "replacement": "劇本裡"}
      ]
    }
  ],

  "suspicious_patterns": [
    {
      "char": "幹",
      "description": "可能需要 幹→乾 修正",
      "before_exclude": ["軀", "主", "事", "能", "若"],
      "after_exclude": ["掉", "活", "勁", "嘛", "嗎", "了", "的", "就", "麼", "什", "道", "不", "得", "髒", "腳", "部", "線", "事", "員", "涉", "細胞", "將", "過", "到", "完", "他", "你", "她", "我", "這", "那", "啥", "嚒", "?", "!", "\u2026", ","]
