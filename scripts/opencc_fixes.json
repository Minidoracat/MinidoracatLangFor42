        {"pattern": "發霧", "replacement": "髮霧"},
        {"pattern": "胭脂魚發", "replacement": "胭脂魚髮", "note": "髮型名稱"},
        {"pattern": "掩眼發", "replacement": "掩眼髮", "note": "髮型名稱"}
      ]
    },
    {
      "category": "係→系",
      "description": "系統/系數：「係」應為「系」",
      "rules": [
        {"pattern": "係數", "replacement": "系數"},
        {"pattern": "係統", "replacement": "系統"},
        {"pattern": "關係", "replacement": "關係", "note": "保留不變（正確用法）"}
      ]
    },
    {
      "category": "面→麵",
      "description": "麵食相關",
      "rules": [
        {"pattern": "面包", "replacement": "麵包"},
        {"pattern": "面條", "replacement": "麵條"},
        {"pattern": "面粉", "replacement": "麵粉"},
