{
  "_comment": "OpenCC s2twp 後處理修正字典。由 sync_translations.py 讀取。",
  "_usage": "新增修正：在對應 category 的 rules 陣列中加入 {pattern, replacement} 即可。",

  "post_fixes": [
    {
      "category": "幹→乾",
      "description": "乾燥、乾貨相關：OpenCC 常把「乾」誤轉為「幹」",
      "rules": [
        {"pattern": "幹(大麥捆|羅勒葉|黑鼠尾草|貓糧|洋甘菊|細香蔥|香菜|聚合草|錦葵|狗糧)", "replacement": "乾\\1", "note": "乾燥物品"},
        {"pattern": "幹(黑豆|鷹嘴豆|芸豆|扁豆|豌豆)", "replacement": "乾\\1", "note": "乾燥豆類"},
        {"pattern": "幹(大麻捆|薰衣草花瓣|萬壽菊|薄荷|牛至|歐芹|車前草|罌粟果|玫瑰花瓣|迷迭香|黑麥捆|鼠尾草|向日葵花盤|百里香|菸草|小麥捆|野蒜)", "replacement": "乾\\1", "note": "乾燥植物"},
        {"pattern": "幹(哈瓦那辣椒|墨西哥辣椒)", "replacement": "乾\\1", "note": "乾燥辣椒"},
        {"pattern": "杏幹", "replacement": "杏乾"},
        {"pattern": "幹拉麵", "replacement": "乾拉麵"},
        {"pattern": "口有點幹", "replacement": "口有點乾"},
        {"pattern": "幹\\s*草", "replacement": "乾草", "note": "乾草（飼料），含空格版"},
        {"pattern": "幹燥", "replacement": "乾燥"},
        {"pattern": "幹爽", "replacement": "乾爽"},
        {"pattern": "幹淨", "replacement": "乾淨"},
        {"pattern": "幹糧", "replacement": "乾糧"},
        {"pattern": "幹柴", "replacement": "乾柴"},
        {"pattern": "幹葉", "replacement": "乾葉"},
        {"pattern": "= \"幹\"", "replacement": "= \"乾\"", "note": "UI 溫度狀態 Dry"},
        {"pattern": "風幹", "replacement": "風乾"},
        {"pattern": "晾幹", "replacement": "晾乾"},
        {"pattern": "烘幹", "replacement": "烘乾"},
        {"pattern": "曬幹", "replacement": "曬乾"},
        {"pattern": "吹幹", "replacement": "吹乾"},
        {"pattern": "擦幹", "replacement": "擦乾"},
        {"pattern": "幹巷", "replacement": "乾巷", "note": "街道名 Dry Lane"},
        {"pattern": "弄幹", "replacement": "弄乾"}
      ]
    },
    {
      "category": "幹→干",
      "description": "干擾、干預：「干」不是「乾」也不是「幹」",
      "rules": [
        {"pattern": "幹\\s*擾", "replacement": "干擾", "note": "含空格版（傳單排版）"},
        {"pattern": "幹預", "replacement": "干預"}
      ]
    },
    {
